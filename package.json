{
  "name": "estimatenest",
  "version": "0.1.0",
  "private": true,
  "description": "Planning Poker Room for Team Estimations",
  "author": "Cagliostro",
  "license": "MIT",
  "workspaces": [
    "frontend",
    "backend",
    "infrastructure",
    "e2e",
    "packages/shared"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/shared && npm run build --workspace=backend && npm run build --workspace=frontend && npm run build --workspace=infrastructure",
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run dev:server --workspace=backend\"",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write .",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.ts --project=chromium",
    "deploy:dev": "npm run deploy --workspace=infrastructure -- --context env=dev",
    "deploy:prod": "npm run deploy --workspace=infrastructure -- --context env=prod",
    "destroy:dev": "npm run destroy --workspace=infrastructure -- --context env=dev",
    "destroy:prod": "npm run destroy --workspace=infrastructure -- --context env=prod"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@10.0.0"
}
